# OpenWeather API ключ для виджета погоды
OPENWEATHER_API_KEY=your_openweather_api_key
WEATHER_CITY=Moscow

# Секретный ключ для JWT токенов (обязательно сменить в продакшене!)
SECRET_KEY=your-secret-key-change-in-production

# MongoDB (в Docker Compose используется mongodb://mongo:27017)
MONGO_URL=mongodb://localhost:27017

# Redis (в Docker Compose используется redis://redis:6379)
REDIS_URL=redis://localhost:6379
