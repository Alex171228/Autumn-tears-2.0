FROM golang:1.25-alpine AS builder

WORKDIR /src
COPY go-services/go.mod ./go.mod
RUN go mod download

COPY go-services ./
ARG SERVICE_CMD
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/service ./${SERVICE_CMD}

FROM alpine:3.21
WORKDIR /app
COPY --from=builder /out/service /app/service
EXPOSE 8000
CMD ["/app/service"]
